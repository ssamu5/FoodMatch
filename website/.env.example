# FoodMatch website build configuration. Copy to .env and fill in as needed.
# NEVER commit a real .env. These are documented for the FUTURE Google Places
# integration only; the site builds fine with the defaults (curated seed data).

# Data source for the public restaurant pages.
#   seed   -> curated pilot dataset parsed from the app seed (default)
#   google -> Google Places API (not implemented yet; see src/placesService.mjs)
FOODMATCH_DATA_SOURCE=seed

# Required only when FOODMATCH_DATA_SOURCE=google. Restrict the key to the
# Places API and to your build IP/CI. Never expose it in client-side code.
GOOGLE_PLACES_API_KEY=

# Public base URL, used for canonical and sitemap URLs.
SITE_URL=https://foodmatch.es
