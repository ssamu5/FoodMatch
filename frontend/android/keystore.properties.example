# Android release signing config. Copy to `keystore.properties` and fill in.
# The real keystore.properties and the .jks/.keystore are gitignored: never
# commit signing secrets. See docs/MOBILE_BUILD.md for how to generate the key.
#
# storeFile is resolved relative to the android/ directory (rootProject), so an
# absolute path is safest.
storeFile=/absolute/path/to/foodmatch-release.jks
storePassword=your-keystore-password
keyAlias=foodmatch
keyPassword=your-key-password
