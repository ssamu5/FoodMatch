# FoodMatch frontend environment. Copy to .env and fill in.
# Real .env is gitignored; never commit secrets.

# Supabase project URL + anon (public) key. Safe to ship in the client:
# the anon key is designed to be public; security is enforced by RLS policies.
# When BOTH are set, the app reads live data via SupabaseSource; otherwise it
# falls back to the bundled seed data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key: SECRET, server-side only. NOT VITE_ prefixed so Vite
# never bundles it into the client. Used only by scripts/migrateToSupabase.mjs
# for the one-time data load. Do not put this in any client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
