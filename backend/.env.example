# FoodMatch backend environment. Copy to .env and fill in. .env is gitignored.

# Database (Postgres). Required for Prisma migrate/seed and all DB access.
DATABASE_URL="postgresql://user:password@localhost:5432/foodmatch"

# JWT signing secret. REQUIRED in production: the server refuses to start with a
# missing secret when NODE_ENV=production (no hardcoded fallback). Use a long
# random value. Outside production a dev fallback is used for convenience.
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"

# Optional integrations (not required to run the API).
# OPENAI_API_KEY: reserved for AI-assisted craving parsing/recommendations.
OPENAI_API_KEY=""
# STRIPE_API_KEY: reserved for future billing (Pro/Founder/Boost). Currently
# UNUSED. No real charges happen without it. See docs/REVENUE_MODEL.md.
STRIPE_API_KEY=""

# App
PORT=5000
NODE_ENV=development
